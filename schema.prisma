// Prisma schema para WINNER STORE v3.2

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // Cambiar a "sqlite" para desarrollo local
  url      = env("DATABASE_URL")
}

model Product {
  id          String      @id
  name        String
  price       Float
  oldPrice    Float?      @map("old_price")
  cost        Float       @default(0)
  category    String?
  image       String?
  badge       String?
  badgeType   String?     @map("badge_type")
  sku         String?     @unique
  description String?
  onSale      Boolean     @default(false) @map("on_sale")
  promoPrice  Float?      @map("promo_price")
  stockStatus String?     @map("stock_status")
  metadata    Json?       // Para datos flexibles de Google Merchant, colores, etc.
  createdAt   DateTime    @default(now()) @map("created_at")
  inventory   Inventory[]
  saleItems   SaleItem[]
  reorderRules    ReorderRule[]
  demandForecasts DemandForecast[]
  reviews         Review[]

  @@map("products")
  @@index([category])
  @@index([sku])
}

model Inventory {
  id           String   @id @default(cuid())
  productId    String   @map("product_id")
  size         String
  quantity     Int      @default(0)
  barcode      String?  @unique
  minStock     Int      @default(2) @map("min_stock")
  location     String?
  lastUpdated  DateTime @default(now()) @updatedAt @map("last_updated")
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, size])
  @@map("inventory")
  @@index([barcode])
}

model Sale {
  id              String     @id
  customerName    String     @map("customer_name")
  customerEmail   String?    @map("customer_email")
  customerPhone   String?    @map("customer_phone")
  totalAmount     Float      @map("total_amount")
  paymentMethod   String?    @map("payment_method")
  paymentStatus   String?    @default("pending") @map("payment_status")
  shippingAddress String?    @map("shipping_address")
  referenceNumber String?    @unique @map("reference_number")
  createdAt       DateTime   @default(now()) @map("created_at")
  salePayments    SalePayment[]
  items           SaleItem[]
  orders          Order[]

  @@map("sales")
  @@index([createdAt])
  @@index([paymentStatus])
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String  @map("sale_id")
  productId String  @map("product_id")
  size      String?
  quantity  Int     @default(1)
  unitPrice Float   @map("unit_price")
  discount  Float?  @default(0)
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("sale_items")
}

model CustomerProfile {
  id           String    @id @default(cuid())
  email        String?   @unique
  phone        String?
  name         String?
  document     String?
  country      String?   @default("CO")
  vipStatus    String?   @default("regular") @map("vip_status")
  lastPurchase DateTime? @map("last_purchase")
  totalSpent   Float     @default(0) @map("total_spent") // total_spent
  totalOrders  Int       @default(0) @map("total_orders") // total_orders
  createdAt    DateTime  @default(now()) @map("created_at")

  @@map("customer_profiles")
}

model SalePayment {
  id        Int      @id @default(autoincrement())
  saleId    String   @map("sale_id")
  amount    Float
  method    String
  notes     String?
  timestamp DateTime @default(now()) @map("created_at")
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@map("sale_payments")
}

model Order {
  id                String    @id @default(cuid())
  saleId            String    @map("sale_id")
  customerEmail     String?   @map("customer_email")
  customerPhone     String?   @map("customer_phone")
  shippingAddress   String?   @map("shipping_address")
  shippingMethod    String?   @map("shipping_method")
  shippingCost      Float?    @map("shipping_cost")
  status            String?   @default("pending")
  trackingNumber    String?   @map("tracking_number")
  estimatedDelivery DateTime? @map("estimated_delivery")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  sale              Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@map("orders")
}

model ShippingOption {
  id          String  @id @default(cuid())
  name        String
  description String?
  price       Float
  enabled     Boolean @default(true)
  priority    Int     @default(0)

  @@map("shipping_options")
}

model ReorderRule {
  id           String  @id @default(cuid())
  productId    String  @map("product_id")
  minStock     Int     @map("min_stock")
  qtyToOrder   Int     @map("qty_to_order")
  reorderCost  Float   @default(0) @map("reorder_cost")
  enabled      Boolean @default(true)
  product      Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("reorder_rules")
}

model DemandForecast {
  id             String    @id @default(cuid())
  productId      String    @map("product_id")
  predictedQty   Int       @map("predicted_qty")
  confidenceScore Float    @map("confidence_score")
  trend          String?
  lastUpdated    DateTime  @default(now()) @map("last_updated")
  product        Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("demand_forecast")
}

model Expense {
  id          String   @id
  description String
  amount      Float
  date        DateTime @db.Date // Campo para la fecha del gasto
  category    String   @default("General")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("expenses")
}

model Review {
  id          String   @id
  name        String
  rating      Int
  comment     String
  suggestion  String?
  productId   String?  @map("product_id")
  status      String   @default("APPROVED")
  createdAt   DateTime @default(now()) @map("created_at")
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@map("reviews")
}