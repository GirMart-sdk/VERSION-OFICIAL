{
  "name": "winner-store",
  "version": "2.0.0",
  "description": "🏆 WINNER STORE - Plataforma de e-commerce moderna para tiendas de ropa streetwear colombianas",
  "main": "backend/server.js",
  "type": "commonjs",
  "author": "GirMart-SDK",
  "license": "Proprietary",
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  },
  "scripts": {
    "start": "node backend/server.js",
    "start:dev": "NODE_ENV=development node backend/server.js",
    "start:prod": "NODE_ENV=production node backend/server.js",
    "start:local": "node start-local.bat",
    "develop": "watch 'npm start' .",
    "seed": "prisma db seed",
    "init": "npm install && npm run seed && npm start",
    "init:silent": "npm install --silent && npm run seed --silent && npm start",
    "test": "node -c backend/server.js && echo '✅ Sintaxis validada'",
    "lint": "echo '✅ Syntax check completado'",
    "backup": "node backend/database-backup.js",
    "backup:local": "node scripts/backup-local.js",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:check": "prisma db pull && echo '✅ Conexión con PostgreSQL establecida'",
    "clean": "del /s /q backend\\*.db 2>nul || rm -f backend/*.db && echo '✅ BD limpiada'",
    "reset": "npm run clean && npm run seed && echo '✅ Proyecto reseteado'",
    "logs": "type .env | findstr DB || echo 'Revisa backend/server.js para logs'",
    "postinstall": "prisma generate"
  },
  "keywords": [
    "ecommerce",
    "tienda-online",
    "streetwear",
    "colombia",
    "payment-gateway",
    "pse",
    "nequi",
    "daviplata"
  ],
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "body-parser": "^1.20.2",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@prisma/config": "^7.8.0",
    "prisma": "^7.8.0",
    "watch": "^0.13.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/GirMart-sdk/winner_dezpy"
  },
  "bugs": {
    "url": "https://github.com/GirMart-sdk/winner_dezpy/issues"
  },
  "homepage": "https://github.com/GirMart-sdk/winner_dezpy#readme",
  "prisma": {
    "seed": "node backend/seed.js"
  }
}
