{
  "name": "winner-store-app",
  "version": "1.0.0",
  "description": "Aplicación de gestión para Winner Store",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "test": "jest",
    "build:admin:js": "esbuild src/admin-bundle.js --bundle --outfile=public/admin-bundle.js --minify --drop:console --drop:debugger --legal-comments=none --tree-shaking=true",
    "build:admin:css": "esbuild src/admin-bundle.css --bundle --outfile=public/admin-bundle.css --minify",
    "watch:admin": "esbuild src/admin-bundle.js --bundle --outfile=public/admin-bundle.js --watch",
    "build:store": "esbuild src/store-bundle.js --bundle --outfile=public/store-bundle.js --minify --drop:console --drop:debugger --legal-comments=none --tree-shaking=true",
    "build": "npm run build:admin:js && npm run build:admin:css && npm run build:store",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^5.15.0",
    "@prisma/client": "^5.15.0",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "cropperjs": "^1.5.13",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.4",
    "helmet": "^7.1.0",
    "html5-qrcode": "^2.3.8",
    "joi": "^17.13.3",
    "jsbarcode": "^3.11.5",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.7",
    "pdfkit": "^0.15.2",
    "pg": "^8.12.0",
    "qrcodejs": "^1.0.0",
    "sharp": "^0.33.0",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "esbuild": "^0.19.5",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "prisma": "^5.15.0",
    "supertest": "^7.0.0"
  }
}
