// Prisma schema para WINNER STORE v3.2

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // Cambiar a "sqlite" para desarrollo local
}

model Product {
  id          String      @id
  name        String
  price       Float
  oldPrice    Float?
  cost        Float       @default(0)
  category    String?
  image       String?
  badge       String?
  description String?
  stockStatus String?     @map("stock_status")
  createdAt   DateTime    @default(now()) @map("created_at")
  inventory   Inventory[]
  saleItems   SaleItem[]

  @@map("products")
}

model Inventory {
  id           String   @id @default(cuid())
  productId    String   @map("product_id")
  size         String?
  quantity     Int?
  reorderLevel Int      @default(5) @map("reorder_level")
  lastUpdated  DateTime @default(now()) @map("last_updated")
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("inventory")
}

model Sale {
  id              String     @id
  customerName    String     @map("customer_name")
  customerEmail   String?    @map("customer_email")
  customerPhone   String?    @map("customer_phone")
  totalAmount     Float      @map("total_amount")
  paymentMethod   String?    @map("payment_method")
  paymentStatus   String?    @default("pending") @map("payment_status")
  shippingAddress String?    @map("shipping_address")
  referenceNumber String?    @unique @map("reference_number")
  createdAt       DateTime   @default(now()) @map("created_at")
  items           SaleItem[]
  orders          Order[]

  @@map("sales")
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String  @map("sale_id")
  productId String  @map("product_id")
  size      String?
  quantity  Int?
  unitPrice Float?  @map("unit_price")
  discount  Float?  @default(0)
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("sale_items")
}

model CustomerProfile {
  id           String    @id @default(cuid())
  email        String?   @unique
  phone        String?
  name         String?
  document     String?
  lastPurchase DateTime? @map("last_purchase")
  totalSpent   Float     @default(0) @map("total_spent")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@map("customer_profiles")
}

model Order {
  id                String    @id @default(cuid())
  saleId            String    @map("sale_id")
  status            String?   @default("pending")
  trackingNumber    String?   @map("tracking_number")
  estimatedDelivery DateTime? @map("estimated_delivery")
  createdAt         DateTime  @default(now()) @map("created_at")
  sale              Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@map("orders")
}