generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String?  @unique
  password  String   // Hash de la contraseña
  role      String   @default("admin")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  auditLogs AuditLog[]

  @@map("users")
}

model AuditLog {
  id         String   @id @default(uuid())
  adminId    String   @map("admin_id")
  action     String   // "CREATE", "UPDATE", "DELETE", "LOGIN"
  targetType String   // "PRODUCT", "EXPENSE", "SALE", "INVENTORY"
  targetId   String?  @map("target_id")
  details    Json?    // Datos del cambio (ej. { "oldPrice": 100, "newPrice": 120 })
  ip         String?  @db.VarChar(45)
  createdAt  DateTime @default(now()) @map("created_at")
  admin      User     @relation(fields: [adminId], references: [id])

  @@map("audit_logs")
}

model BlacklistedToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime @map("expires_at")

  @@map("blacklisted_tokens")
}

model BannedIp {
  id        String   @id @default(uuid())
  ip        String   @unique
  reason    String?
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("banned_ips")
}

model Product {
  id              String           @id @db.VarChar(50)
  name            String           @db.VarChar(255)
  price           Decimal          @db.Decimal(12, 2)
  old_price       Decimal?         @db.Decimal(12, 2)
  cost            Decimal?         @default(0) @db.Decimal(12, 2)
  category        String?          @db.VarChar(50)
  image           String?
  badge           String?          @db.VarChar(50)
  badgeType       String?          @map("badge_type") @db.VarChar(50)
  sku             String?          @unique @db.VarChar(100)
  description     String?
  onSale          Boolean?         @default(false) @map("on_sale")
  promo_price     Decimal?         @db.Decimal(12, 2)
  createdAt       DateTime?        @default(now()) @map("created_at") @db.Timestamp(6)
  updated_at      DateTime?        @default(now()) @db.Timestamp(6)
  demandForecasts DemandForecast[]
  inventory       Inventory[]
  saleItems       SaleItem[]
  reorderRules    ReorderRule[]

  @@index([category], map: "idx_products_category")
  @@index([sku], map: "idx_products_sku")
  @@map("products")
}

model Inventory {
  productId  String    @map("product_id") @db.VarChar(50)
  size       String    @db.VarChar(10)
  quantity   Int?      @default(0)
  barcode    String?   @unique @db.VarChar(100)
  minStock   Int?      @default(2) @map("min_stock")
  location   String?   @db.VarChar(100)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([productId, size])
  @@index([productId], map: "idx_inventory_product")
  @@map("inventory")
}

model Sale {
  id               String     @id @db.VarChar(50)
  createdAt        DateTime?  @default(now()) @map("created_at") @db.Timestamp(6)
  channel          String?    @db.VarChar(50)
  vendor           String?    @db.VarChar(100)
  customerName     String?    @map("client") @db.VarChar(255)
  method           String?    @db.VarChar(50)
  subtotal         Decimal?   @default(0) @db.Decimal(12, 2)
  discount         Decimal?   @default(0) @db.Decimal(12, 2)
  totalAmount      Decimal    @map("total") @db.Decimal(12, 2)
  paymentMethod    String?    @map("payment_method") @db.VarChar(50)
  paymentStatus    String?    @default("completed") @map("payment_status") @db.VarChar(50)
  customerEmail    String?    @map("customer_email") @db.VarChar(255)
  customerPhone    String?    @map("customer_phone") @db.VarChar(20)
  shippingAddress  String?    @map("shipping_address")
  shippingCarrier  String?    @map("shipping_carrier") @db.VarChar(100)
  referenceNumber  String?    @map("reference_number") @db.VarChar(100)
  payment_details  Json?
  deletedAt        DateTime?  @map("deleted_at") @db.Timestamp(6)
  items_summary    String?    @map("items")
  items            SaleItem[]
  salePayments     SalePayment[]
  orders           Order[]

  @@index([createdAt], map: "idx_sales_timestamp")
  @@map("sales")
}

model SaleItem {
  id           Int     @id @default(autoincrement())
  saleId       String  @map("sale_id") @db.VarChar(50)
  productId    String? @map("product_id") @db.VarChar(50)
  product_name String  @db.VarChar(255)
  quantity     Int     @map("qty")
  unitPrice    Decimal @map("price") @db.Decimal(12, 2)
  size         String? @db.VarChar(10)
  sale         Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  product      Product? @relation(fields: [productId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@map("sale_items")
}

model SalePayment {
  id        Int      @id @default(autoincrement())
  saleId    String   @map("sale_id") @db.VarChar(50)
  timestamp DateTime @default(now()) @db.Timestamp(6)
  amount    Decimal  @db.Decimal(12, 2)
  method    String?  @db.VarChar(50)
  notes     String?
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("sale_payments")
}

model Order {
  id              String   @id @db.VarChar(50)
  saleId          String   @map("sale_id") @db.VarChar(50)
  status          String?  @default("PENDIENTE") @db.VarChar(50)
  shippingMethod  String?  @map("shipping_method") @db.VarChar(100)
  shippingAddress String?  @map("shipping_address")
  shippingCost    Decimal? @default(0) @map("shipping_cost") @db.Decimal(12, 2)
  trackingNumber  String?  @map("tracking_number") @db.VarChar(100)
  customerEmail   String?  @map("customer_email") @db.VarChar(255)
  customerPhone   String?  @map("customer_phone") @db.VarChar(20)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime @default(now()) @map("updated_at") @db.Timestamp(6)
  sale            Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("orders")
}

model Expense {
  id          String   @id @db.VarChar(50)
  category    String?  @db.VarChar(100)
  concept     String?  @db.VarChar(255)
  detail      String?
  method      String?  @default("Efectivo") @db.VarChar(50)
  amount      Decimal  @db.Decimal(12, 2)
  description String?
  date        DateTime @default(now()) @db.Date
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt   DateTime? @default(now()) @map("updated_at") @db.Timestamp(0)

  @@map("expenses")
}

model CashSession {
  id                String    @id @db.VarChar(50)
  openedAt          DateTime  @default(now()) @map("opened_at") @db.Timestamp(6)
  closedAt          DateTime? @map("closed_at") @db.Timestamp(6)
  openedBy          String    @map("opened_by") @db.VarChar(100)
  closedBy          String?   @map("closed_by") @db.VarChar(100)
  initialBalance    Decimal   @default(0) @map("initial_balance") @db.Decimal(12, 2)
  theoreticalSales  Decimal   @default(0) @map("theoretical_sales") @db.Decimal(12, 2)
  theoreticalExpenses Decimal @default(0) @map("theoretical_expenses") @db.Decimal(12, 2)
  realBalance       Decimal?  @map("real_balance") @db.Decimal(12, 2)
  difference        Decimal?  @db.Decimal(12, 2)
  status            String    @default("OPEN") @db.VarChar(20)
  notes             String?

  @@map("cash_sessions")
}

model CustomerProfile {
  id           String    @id @default(uuid()) @db.VarChar(50)
  email        String?   @unique @db.VarChar(255)
  name         String?   @db.VarChar(255)
  phone        String?   @db.VarChar(20)
  country      String?   @default("CO") @db.VarChar(50)
  totalSpent   Decimal?  @default(0) @map("total_spent") @db.Decimal(12, 2)
  totalOrders  Int?      @default(0) @map("total_orders")
  lastPurchase DateTime? @map("last_purchase") @db.Timestamp(6)
  vipStatus    String?   @default("regular") @map("vip_status") @db.VarChar(50)
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  @@index([email], map: "idx_customer_email")
  @@map("customer_profiles")
}

model ReorderRule {
  id          String   @id @db.VarChar(50)
  productId   String   @map("product_id") @db.VarChar(50)
  minStock    Int      @map("min_stock")
  qtyToOrder  Int      @map("qty_to_order")
  reorderCost Decimal? @default(0) @map("reorder_cost") @db.Decimal(12, 2)
  enabled     Int?     @default(1)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("reorder_rules")
}

model DemandForecast {
  id              String    @id @default(uuid()) @db.VarChar(50)
  productId       String    @map("product_id") @db.VarChar(50)
  predictedQty    Int?      @map("predicted_qty")
  confidenceScore Decimal?  @map("confidence_score") @db.Decimal(5, 2)
  trend           String?   @db.VarChar(20)
  lastUpdated     DateTime? @default(now()) @map("last_updated") @db.Timestamp(6)
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("demand_forecast")
}
